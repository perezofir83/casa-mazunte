# ============================================
# Casa Mazunte - Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to git!
# ============================================

# App
NODE_ENV=development
PORT=3000

# Database (SQLite for local dev)
DATABASE_URL="file:./dev.db"

# Claude API (for listing parsing)
# Get your key at: https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-your-key-here

# Ultramsg (WhatsApp API)
# Leave empty to disable notifications in dev
ULTRAMSG_INSTANCE_ID=
ULTRAMSG_TOKEN=

# Security
JWT_SECRET=change-this-to-a-random-32-char-string-minimum
PHONE_ENCRYPTION_KEY=change-this-to-exactly-32-chars!

# CORS
CORS_ORIGIN=http://localhost:3001

# Image Storage
IMAGE_STORAGE=local
IMAGE_LOCAL_PATH=./uploads
# GCS_BUCKET=casa-mazunte-images  # For production only

# Capture API Key (shared secret with Chrome extension / Claude in Chrome)
CAPTURE_API_KEY=dev-capture-key-change-in-production
